void setup() {
  Serial.begin(115200);
  Serial.println("\nAQM9 Sensor Display System Starting...");
  
  u8g2.begin();
  u8g2.enableUTF8Print();
  
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB08_tr);
  u8g2.setCursor(0, 20);
  u8g2.print("Starting...");
  u8g2.sendBuffer();
  delay(2000);
  
  setupWiFi();
  setupFirebase();
  
  if (!bme.begin(BME280_ADDR)) {
    Serial.println("BME280 not found!");
  }
  
  initSettingsAndFlags();
  initLEDs();
  initSensorThresholds();
  initVariables();
  setTempScale();
  updateBuzzerAndDisplayModeState();
  
  last_update = millis();
  last_serial_print = millis();
  last_display_update = millis();
  last_alert_check = millis();
  last_offset_update = millis();
  lastFirebaseSend = millis();
  lastHistorySave = millis();  // Initialize history save timer
  last_button_check = millis();
  
  u8g2.clearBuffer();
  u8g2.sendBuffer();
  
  Serial.println("Setup Complete!");
}

void loop() {
  unsigned long now = millis();
  
  if (now - last_button_check >= 100) {
    last_button_check = now;
    checkButtons();
  }
  
  if (now - last_update >= 1000) {
    last_update = now;
    tick++;
    loadSensorValues();
    shineleds();
    computeAirQuality();
    if (cold_start && tick >= (unsigned long)(time_to_cold_start * 1000)) {
      cold_start = false;
    }
  }
  
  if (now - last_serial_print >= 5000) {
    last_serial_print = now;
    printToSerial();
  }
  
  if (now - lastFirebaseSend >= firebaseSendInterval) {
    lastFirebaseSend = now;
    sendToFirebase();
  }
  
  // Save history every 30 minutes
  if (now - lastHistorySave >= historySaveInterval) {
    lastHistorySave = now;
    saveToHistory();
  }
  
  updateDisplay();
  
  if (now - last_alert_check >= 60000) {
    last_alert_check = now;
    raiseAlert();
    checkAutoRestart();
  }
  
  if (now - last_offset_update >= 3600000) {
    last_offset_update = now;
    setTempoffset();
  }
  
  delay(100);
}
