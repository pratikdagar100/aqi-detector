void sendLiveDataToFirebase() {
  if (!signupOK) return;
  
  String deviceId = getDeviceId();
  String path = "/devices/" + deviceId + "/live/";
  
  Firebase.RTDB.setFloat(&fbdo, path + "co2", co2_value);
  Firebase.RTDB.setFloat(&fbdo, path + "pm25", pm25_value);
  Firebase.RTDB.setFloat(&fbdo, path + "pm10", pm10_value);
  Firebase.RTDB.setFloat(&fbdo, path + "pm1", pm1_value);
  Firebase.RTDB.setFloat(&fbdo, path + "voc", voc_index_value);
  Firebase.RTDB.setFloat(&fbdo, path + "nox", nox_index_value);
  Firebase.RTDB.setFloat(&fbdo, path + "temperature", aht_temp);
  Firebase.RTDB.setFloat(&fbdo, path + "humidity", aht_hum);
  Firebase.RTDB.setFloat(&fbdo, path + "pressure", aht_hpa);
  Firebase.RTDB.setInt(&fbdo, path + "air_quality", air_quality);
  Firebase.RTDB.setFloat(&fbdo, path + "timestamp", millis() / 1000.0);
}

void saveToHistory() {
  if (!signupOK) return;
  
  String deviceId = getDeviceId();
  unsigned long timestamp = millis() / 1000;
  String historyPath = "/devices/" + deviceId + "/history/" + String(timestamp);
  
  Serial.println("Saving 30-minute history...");
  
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/co2", co2_value);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/pm25", pm25_value);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/pm10", pm10_value);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/pm1", pm1_value);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/voc", voc_index_value);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/nox", nox_index_value);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/temperature", aht_temp);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/humidity", aht_hum);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/pressure", aht_hpa);
  Firebase.RTDB.setInt(&fbdo, historyPath + "/air_quality", air_quality);
  Firebase.RTDB.setFloat(&fbdo, historyPath + "/recorded_at", timestamp);
  
  // Update recent snapshot
  String recentPath = "/devices/" + deviceId + "/recent/";
  Firebase.RTDB.setFloat(&fbdo, recentPath + "co2", co2_value);
  Firebase.RTDB.setFloat(&fbdo, recentPath + "pm25", pm25_value);
  Firebase.RTDB.setFloat(&fbdo, recentPath + "temperature", aht_temp);
  Firebase.RTDB.setFloat(&fbdo, recentPath + "humidity", aht_hum);
  Firebase.RTDB.setFloat(&fbdo, recentPath + "last_update", timestamp);
  
  // Add to history list
  String listPath = "/devices/" + deviceId + "/history_list/";
  Firebase.RTDB.setFloat(&fbdo, listPath + String(timestamp), timestamp);
  
  Serial.println("History saved!");
}

