void ledsOff() {
  digitalWrite(LED1_PIN, LOW);
  digitalWrite(LED2_PIN, LOW);
  digitalWrite(LED3_PIN, LOW);
}

void setLedState(int lednum, int color) {
  int ledPin;
  int brightness;
  
  if (lednum == 1) ledPin = LED1_PIN;
  else if (lednum == 2) ledPin = LED2_PIN;
  else ledPin = LED3_PIN;
  
  switch(color) {
    case 1: brightness = 20; break;
    case 2: brightness = 50; break;
    case 3: brightness = 100; break;
    case 4: 
      if ((millis() / 500) % 2 == 0) brightness = 100;
      else brightness = 0;
      break;
    default: brightness = 0;
  }
  
  int pwmValue = map(brightness, 0, 100, 0, 255);
  analogWrite(ledPin, pwmValue);
}

void checkButtons() {
  bool button1State = digitalRead(BUTTON1_PIN);
  bool button2State = digitalRead(BUTTON2_PIN);
  
  if (button1State == LOW && lastButton1State == HIGH) {
    display_mode++;
    if (display_mode > 1) display_mode = 0;
    buzzer(1);
    delay(200);
  }
  
  if (button2State == LOW && lastButton2State == HIGH) {
    buzzer_active = !buzzer_active;
    if (buzzer_active) buzzer(1);
    delay(200);
  }
  
  lastButton1State = button1State;
  lastButton2State = button2State;
}

int getPollutionLevel(float value, float normal, float moderate, float high) {
  if (value <= normal) return 1;
  else if (value <= moderate) return 2;
  else if (value <= high) return 3;
  else return 4;
}

void buzzer(int beeps) {
  if (buzzer_active) {
    for (int i = 0; i < beeps; i++) {
      tone(BUZZER_PIN, 2000, 150);
      delay(200);
      noTone(BUZZER_PIN);
      delay(100);
    }
  }
}

// ============ MAIN SENSOR READING FUNCTION ============
void loadSensorValues() {
  // Read BME280 if available
  if (bme.begin(BME280_ADDR)) {
    aht_temp = bme.readTemperature();
    aht_hum = bme.readHumidity();
    aht_hpa = bme.readPressure() / 100.0F;
  }
  
  // Read CO2 sensor (if available)
  int co2 = readCO2();
  if (co2 > 0 && co2 < 5000) {
    co2_value = co2;
  }
  
  // Read PMS5003 (if available)
  PMSData pms = readPMS();
  if (pms.pm1_0 > 0 && pms.pm1_0 < 1000) {
    pm1_value = pms.pm1_0;
    pm25_value = pms.pm2_5;
    pm10_value = pms.pm10;
  }
  
  // Update simulated values for sensors not connected
  updateSimulatedValues();
}

void computeAirQuality() {
  int co2Level = getPollutionLevel(co2_value, 800, 1200, 2000);
  int pmLevel = getPollutionLevel(pm25_value, 35, 75, 150);
  int vocLevel = getPollutionLevel(voc_index_value, 100, 200, 350);
  int noxLevel = getPollutionLevel(nox_index_value, 50, 100, 200);
  
  air_quality = max(max(co2Level, pmLevel), max(vocLevel, noxLevel));
}

void shineleds() {
  int co2Level = getPollutionLevel(co2_value, 800, 1200, 2000);
  int pmLevel = getPollutionLevel(pm25_value, 35, 75, 150);
  int vocLevel = getPollutionLevel(voc_index_value, 100, 200, 350);
  int noxLevel = getPollutionLevel(nox_index_value, 50, 100, 200);
  int vocNoxCombined = max(vocLevel, noxLevel);
  
  setLedState(1, co2Level);
  setLedState(2, pmLevel);
  setLedState(3, vocNoxCombined);
}

