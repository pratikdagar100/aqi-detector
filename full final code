// ============ CO2 SENSOR (MHZ19B) ============
HardwareSerial co2Serial(2);

int readCO2() {
  byte cmd[9] = {0xFF, 0x01, 0x86, 0x00, 0x00, 0x00, 0x00, 0x00, 0x79};
  byte response[9];
  
  co2Serial.write(cmd, 9);
  delay(100);
  
  if (co2Serial.available() >= 9) {
    for (int i = 0; i < 9; i++) {
      response[i] = co2Serial.read();
    }
    
    byte checksum = 0;
    for (int i = 1; i < 8; i++) {
      checksum += response[i];
    }
    checksum = 0xFF - checksum + 1;
    
    if (response[8] == checksum) {
      int co2 = response[2] * 256 + response[3];
      if (co2 > 0 && co2 < 5000) {
        return co2;
      }
    }
  }
  return -1;
}

// ============ PMS5003 SENSOR ============
HardwareSerial pmsSerial(1);

PMSData readPMS() {
  PMSData data;
  data.pm1_0 = -1;
  data.pm2_5 = -1;
  data.pm10 = -1;
  
  uint8_t buffer[32];
  uint8_t idx = 0;
  
  while (pmsSerial.available() && idx < 32) {
    buffer[idx++] = pmsSerial.read();
  }
  
  for (int i = 0; i < idx - 8; i++) {
    if (buffer[i] == 0x42 && buffer[i+1] == 0x4D) {
      uint16_t checksum = 0;
      for (int j = 0; j < 30; j++) {
        checksum += buffer[i+j];
      }
      
      uint16_t receivedChecksum = (buffer[i+30] << 8) | buffer[i+31];
      
      if (checksum == receivedChecksum) {
        data.pm1_0 = (buffer[i+10] << 8) | buffer[i+11];
        data.pm2_5 = (buffer[i+12] << 8) | buffer[i+13];
        data.pm10 = (buffer[i+14] << 8) | buffer[i+15];
        break;
      }
    }
  }
  
  return data;
}

// ============ UPDATE VALUES WITH REALISTIC VARIATIONS ============
void updateSimulatedValues() {
  static unsigned long lastUpdate = 0;
  if (millis() - lastUpdate > 30000) { // Update every 30 seconds
    lastUpdate = millis();
    
    // CO2 variations (normal indoor: 400-800 ppm)
    co2_value = 400 + random(0, 100);
    
    // PM2.5 variations (normal: 0-35 µg/m³)
    pm25_value = 5 + random(0, 30);
    pm10_value = pm25_value + random(-5, 10);
    if (pm10_value < pm25_value) pm10_value = pm25_value + 2;
    pm1_value = pm25_value * 0.6 + random(-3, 5);
    if (pm1_value < 1) pm1_value = 2;
    
    // VOC/NOx variations
    voc_index_value = 50 + random(-20, 50);
    if (voc_index_value < 20) voc_index_value = 20;
    if (voc_index_value > 250) voc_index_value = 250;
    
    nox_index_value = 10 + random(-8, 20);
    if (nox_index_value < 5) nox_index_value = 5;
    if (nox_index_value > 80) nox_index_value = 80;
    
    // Temperature variations (slow change)
    aht_temp = aht_temp + random(-5, 5) / 10.0;
    if (aht_temp < 18) aht_temp = 18;
    if (aht_temp > 38) aht_temp = 38;
    
    // Humidity variations
    aht_hum = aht_hum + random(-3, 3);
    if (aht_hum < 20) aht_hum = 20;
    if (aht_hum > 80) aht_hum = 80;
    
    // Pressure variations
    aht_hpa = aht_hpa + random(-3, 3);
    if (aht_hpa < 980) aht_hpa = 980;
    if (aht_hpa > 1020) aht_hpa = 1020;
  }
}

