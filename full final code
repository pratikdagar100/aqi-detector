// ============ ALERT FUNCTION ============
void raiseAlert() {
  if (air_quality >= 3 && buzzer_active) {
    unsigned long now = millis();
    if (now - lastBuzzerAlert >= 60000) {
      lastBuzzerAlert = now;
      int beeps = (air_quality == 3) ? 2 : 3;
      buzzer(beeps);
      Serial.println("⚠️ HIGH POLLUTION ALERT! ⚠️");
    }
  }
}

void setupWiFi() {
  Serial.print("Connecting to WiFi");
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  Serial.println();
  if (WiFi.status() == WL_CONNECTED) {
    Serial.print("Connected! IP: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("WiFi connection failed!");
  }
}

void setupFirebase() {
  Serial.println("Setting up Firebase...");
  config.api_key = API_KEY;
  config.database_url = DATABASE_URL;
  auth.user.email = USER_EMAIL;
  auth.user.password = USER_PASSWORD;
  config.token_status_callback = tokenStatusCallback;
  
  Firebase.begin(&config, &auth);
  Firebase.reconnectWiFi(true);
  
  delay(2000);
  signupOK = Firebase.ready();
  
  if (signupOK) {
    Serial.println("Firebase ready!");
  } else {
    Serial.println("Firebase not ready!");
  }
}

void setup() {
  Serial.begin(115200);
  Serial.println("\n╔════════════════════════════════════╗");
  Serial.println("║     AQM9 AIR QUALITY MONITOR       ║");
  Serial.println("║        Starting System...          ║");
  Serial.println("╚════════════════════════════════════╝\n");
  
  // Initialize sensor serial ports
  co2Serial.begin(9600, SERIAL_8N1, CO2_RX_PIN, CO2_TX_PIN);
  pmsSerial.begin(9600, SERIAL_8N1, PMS_RX_PIN, PMS_TX_PIN);
  
  // Initialize display
  u8g2.begin();
  u8g2.enableUTF8Print();
  
  // Show startup message
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB08_tr);
  u8g2.setCursor(0, 20);
  u8g2.print("Starting AQM9...");
  u8g2.sendBuffer();
  
  // Initialize BME280
  if (!bme.begin(BME280_ADDR)) {
    Serial.println("⚠️ BME280 not found! Using simulated values.");
  } else {
    Serial.println("✓ BME280 initialized");
  }
  
  // Setup connections
  setupWiFi();
  setupFirebase();
  
  // Initialize LEDs and buttons
  initLEDs();
  
  // Initialize timers
  last_update = millis();
  last_serial_print = millis();
  last_display_update = millis();
  last_alert_check = millis();
  lastFirebaseSend = millis();
  lastHistorySave = millis();
  last_button_check = millis();
  lastSensorRead = millis();
  lastBuzzerAlert = millis();
  lastValueUpdate = millis();
  
  Serial.println("\n✓ System Ready!");
  Serial.println("Values will update every 30 seconds\n");
  delay(2000);
}

void loop() {
  unsigned long now = millis();
  
  // Check buttons
  if (now - last_button_check >= 100) {
    last_button_check = now;
    checkButtons();
  }
  
  // Read sensors every 5 seconds
  if (now - lastSensorRead >= 5000) {
    lastSensorRead = now;
    loadSensorValues();
    computeAirQuality();
    shineleds();
  }
  
  // Update values every 30 seconds (for simulated sensors)
  if (now - lastValueUpdate >= 30000) {
    lastValueUpdate = now;
    updateSimulatedValues();
  }
  
  // Update counter
  if (now - last_update >= 1000) {
    last_update = now;
    tick++;
  }
  
  // Print to serial every 10 seconds
  if (now - last_serial_print >= 10000) {
    last_serial_print = now;
    printToSerial();
  }
  
  // Send live data to Firebase every 10 seconds
  if (now - lastFirebaseSend >= firebaseSendInterval) {
    lastFirebaseSend = now;
    sendLiveDataToFirebase();
  }
  
  // Save history every 30 minutes
  if (now - lastHistorySave >= historySaveInterval) {
    lastHistorySave = now;
    saveToHistory();
  }
  
  // Update display
  updateDisplay();
  
  // Check alerts every 10 seconds
  if (now - last_alert_check >= 10000) {
    last_alert_check = now;
    raiseAlert();
  }
  
  delay(50);
}
