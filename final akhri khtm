  if (pms_available && pm25_value > 0) u8g2.printf("PM2.5: %.0f", pm25_value);
  else u8g2.print("PM2.5: ----");
  
  u8g2.setCursor(0, line3_y);
  if (sgp41_available && voc_index_value > 0) u8g2.printf("VOC/NOx: %.0f/%.0f", voc_index_value, nox_index_value);
  else u8g2.print("VOC/NOx: ----");
  
  u8g2.setCursor(0, line4_y);
  if (aht_hpa > 0) u8g2.printf("Press: %.0f hPa", aht_hpa);
  else u8g2.print("Press: ---- hPa");
  
  u8g2.setCursor(0, line5_y);
  if (aht_temp != 0) u8g2.printf("Temp/RH: %.1fC/%.0f%%", aht_temp, aht_hum);
  else u8g2.print("Temp/RH: --.-C/--%");
  
  u8g2.sendBuffer();
}

