void sendLiveDataToFirebase() {
  if (!signupOK) return;
  
  String deviceId = "AQM9_" + String(WiFi.macAddress());
  deviceId.replace(":", "");
  String path = "/devices/" + deviceId + "/live/";
  
  if (co2_value > 0) Firebase.RTDB.setFloat(&fbdo, path + "co2", co2_value);
  if (pms_available && pm1_value > 0) Firebase.RTDB.setFloat(&fbdo, path + "pm1", pm1_value);
  if (pms_available && pm25_value > 0) Firebase.RTDB.setFloat(&fbdo, path + "pm25", pm25_value);
  if (pms_available && pm10_value > 0) Firebase.RTDB.setFloat(&fbdo, path + "pm10", pm10_value);
  if (sgp41_available && voc_index_value > 0) Firebase.RTDB.setFloat(&fbdo, path + "voc", voc_index_value);
  if (sgp41_available && nox_index_value > 0) Firebase.RTDB.setFloat(&fbdo, path + "nox", nox_index_value);
  if (aht_temp != 0) Firebase.RTDB.setFloat(&fbdo, path + "temperature", aht_temp);
