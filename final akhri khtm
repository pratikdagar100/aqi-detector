  if (aht_hpa > 0) Firebase.RTDB.setFloat(&fbdo, path + "pressure", aht_hpa);
  
  Firebase.RTDB.setInt(&fbdo, path + "air_quality", air_quality);
  Firebase.RTDB.setFloat(&fbdo, path + "timestamp", millis() / 1000.0);
}

