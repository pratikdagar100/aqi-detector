// ================= PMS DATA STRUCTURE =================
struct PMSData {
  int pm1_0;
  int pm2_5;
  int pm10;
};

// ================= CO2 SENSOR =================
int readCO2() {
  byte cmd[9] = {0xFF, 0x01, 0x86, 0, 0, 0, 0, 0, 0x79};
  byte response[9];

  // Clear buffer completely
  while (co2Serial.available()) co2Serial.read();

  // Send command
  co2Serial.write(cmd, 9);

  // Wait for response (IMPORTANT FIX)
  unsigned long start = millis();
  while (co2Serial.available() < 9) {
    if (millis() - start > 500) {
      return -1; // timeout
    }
  }

  // Read full 9 bytes
  for (int i = 0; i < 9; i++) {
    response[i] = co2Serial.read();
  }

  // Validate header
  if (response[0] != 0xFF || response[1] != 0x86) {
    return -1;
  }

  // Check checksum
  byte checksum = 0;
  for (int i = 1; i < 8; i++) checksum += response[i];
  checksum = 0xFF - checksum + 1;

  if (checksum != response[8]) {
    return -1;
  }

  int co2 = (response[2] << 8) | response[3];

  if (co2 > 300 && co2 < 5000) {
    return co2;
  }

  return -1;
}

// ================= PMS5003 SENSOR =================
PMSData readPMS() {
  PMSData d;
  d.pm1_0 = -1;
  d.pm2_5 = -1;
  d.pm10 = -1;
  
  uint8_t buffer[32];
  int idx = 0;

  while (pmsSerial.available() && idx < 32) {
    buffer[idx++] = pmsSerial.read();
  }

  for (int i = 0; i < idx - 8; i++) {
    if (buffer[i] == 0x42 && buffer[i+1] == 0x4D) {
      d.pm1_0 = (buffer[i+10] << 8) | buffer[i+11];
      d.pm2_5 = (buffer[i+12] << 8) | buffer[i+13];
      d.pm10 = (buffer[i+14] << 8) | buffer[i+15];
      break;
    }
  }
  return d;
}

// ================= SGP41 VOC/NOx SENSOR =================
void readSGP41() {
  if (!sgp41_available) return;
  
  uint16_t voc_raw = sgp.measureRaw(aht_temp, aht_hum);
  
  if (voc_raw > 0 && voc_raw < 65000) {
    voc_index_value = map(voc_raw, 0, 65000, 0, 500);
    if (voc_index_value < 0) voc_index_value = 0;
    if (voc_index_value > 500) voc_index_value = 500;
    
    nox_index_value = voc_index_value * 0.3;
    if (nox_index_value < 0) nox_index_value = 0;
    if (nox_index_value > 500) nox_index_value = 500;
  }
}

// ================= LOAD ALL SENSORS =================
void loadSensorValues() {
  // BME280
  if (bme.begin(BME280_ADDR)) {
    aht_temp = bme.readTemperature();
    aht_hum = bme.readHumidity();
    aht_hpa = bme.readPressure() / 100.0;
  }

  // CO2 - Only read after warmup
  if (co2WarmupDone) {
    int co2 = readCO2();
    if (co2 > 0 && co2 < 5000) {
      co2_value = co2;
      co2_available = true;
      Serial.printf("CO2: %d ppm\n", co2);
    }
  } else {
    // During warmup, show increasing value
    unsigned long elapsed = (millis() - co2WarmupStart) / 1000;
    if (elapsed <= 180) {
      co2_value = 400 + (elapsed * 0.5);
      if (co2_value > 490) co2_value = 490;
    }
  }

  // PMS5003
  PMSData p = readPMS();
  if (p.pm1_0 > 0 && p.pm1_0 < 1000) {
    pm1_value = p.pm1_0;
    pm25_value = p.pm2_5;
    pm10_value = p.pm10;
    pms_available = true;
  }

  // SGP41
  readSGP41();
}

// ================= AIR QUALITY CALCULATION =================
int getPollutionLevel(float value, float normal, float moderate, float high) {
  if (value <= normal) return 1;
  else if (value <= moderate) return 2;
  else if (value <= high) return 3;
  else return 4;
}

void computeAirQuality() {
  int co2Level = (co2_available) ? getPollutionLevel(co2_value, 800, 1200, 2000) : 1;
  int pmLevel = (pms_available) ? getPollutionLevel(pm25_value, 35, 75, 150) : 1;
  int vocLevel = (sgp41_available) ? getPollutionLevel(voc_index_value, 100, 200, 350) : 1;
  
  air_quality = max(max(co2Level, pmLevel), vocLevel);
}

