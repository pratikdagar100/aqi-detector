// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  co2WarmupStart = millis();
  
  Serial.println("\n╔════════════════════════════════════╗");
  Serial.println("║     AQM9 AIR QUALITY MONITOR       ║");
  Serial.println("║        Starting System...          ║");
  Serial.println("╚════════════════════════════════════╝\n");
  
  // Initialize UART for sensors
  co2Serial.begin(9600, SERIAL_8N1, CO2_RX_PIN, CO2_TX_PIN);
  pmsSerial.begin(9600, SERIAL_8N1, PMS_RX_PIN, PMS_TX_PIN);
  
  // Initialize I2C
  Wire.begin(21, 22);
  
  // Initialize OLED Display
  u8g2.begin();
  u8g2.enableUTF8Print();
  
  // Initialize BME280
  if (!bme.begin(BME280_ADDR)) {
    Serial.println("⚠️ BME280 not found!");
  } else {
    Serial.println("✓ BME280 initialized");
    aht_temp = bme.readTemperature();
    aht_hum = bme.readHumidity();
    aht_hpa = bme.readPressure() / 100.0;
  }
  
  // Initialize SGP40/SGP41
  if (sgp.begin()) {
    Serial.println("✓ SGP41 initialized");
    sgp41_available = true;
  } else {
    Serial.println("⚠️ SGP41 not found!");
  }
  
  // Show startup message
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB08_tr);
  u8g2.setCursor(0, 25);
  u8g2.print("CO2 Warming up...");
  u8g2.sendBuffer();
  
  // Setup connections
  setupWiFi();
  setupFirebase();
  
  // Send reset command to CO2 sensor
  delay(500);
  byte resetCmd[9] = {0xFF, 0x01, 0x78, 0x41, 0x00, 0x00, 0x00, 0x00, 0x46};
  co2Serial.write(resetCmd, 9);
  delay(1000);
  
  Serial.println("\n✓ CO2 sensor will take 3 minutes to stabilize");
  Serial.println("Display will show estimated CO2 during warmup\n");
  
  // Initialize timers
  lastSensorRead = millis();
  lastDisplayUpdate = millis();
  lastSerialPrint = millis();
  lastFirebaseSend = millis();
  lastHistorySave = millis();
  
  // Force first sensor read
  loadSensorValues();
  computeAirQuality();
  updateDisplay();
}

// ================= MAIN LOOP =================
void loop() {
  unsigned long now = millis();
  
  // Mark warmup complete after 3 minutes
  if (!co2WarmupDone && (now - co2WarmupStart) >= 180000) {
    co2WarmupDone = true;
    Serial.println("✓ CO2 sensor warmup complete!");
  }
  
  // Read sensors every 3 seconds
  if (now - lastSensorRead >= 3000) {
    lastSensorRead = now;
    loadSensorValues();
    computeAirQuality();
  }
  
  // Update display every 3 seconds
  if (now - lastDisplayUpdate >= 3000) {
    lastDisplayUpdate = now;
    updateDisplay();
  }
  
  // Print to serial every 10 seconds
  if (now - lastSerialPrint >= 10000) {
    lastSerialPrint = now;
    printToSerial();
  }
  
  // Send to Firebase every 10 seconds
  if (now - lastFirebaseSend >= firebaseSendInterval) {
    lastFirebaseSend = now;
    sendLiveDataToFirebase();
  }
  
  // Save history every 30 minutes
  if (now - lastHistorySave >= historySaveInterval) {
    lastHistorySave = now;
    saveToHistory();
  }
  
  delay(50);
}
